# Rust build artifacts
/target/
**/*.rs.bk
*.pdb
/rust_out

# Local-only cargo config. On Arch, /etc/makepkg.conf leaks `-flto=auto` into
# CFLAGS, which breaks ring's C build under ld.lld; .cargo/config.toml overrides
# CFLAGS to fix it. Kept untracked — its force'd flags (e.g. -fcf-protection)
# would break non-Arch CI runners (notably macOS / Apple clang).
/.cargo/

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# AI assistant artifacts — kept local, not published
Chat.txt
CLAUDE.md
AGENTS.md
GEMINI.md
.claude/
.cursor/
.cursorrules
.aider*

# Nested reference repositories (out-of-tree third-party projects)
# Kept on disk for offline reference during development.
/cruxpass/
/rbw/

# Local environment overrides
.env
.env.*
!.env.example
